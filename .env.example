# Server port (default: 3080)
PORT=3080

# GEMINI_API_KEY: Default Gemini API key for platform-level AI calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# OPENAI_API_KEY: Default OpenAI API key for GPT and DALL-E.
OPENAI_API_KEY="MY_OPENAI_API_KEY"

# Admin login credentials for testing
ADMIN_USER="admin"
ADMIN_PASSWORD="admin123"
ADMIN_API_KEY="dev-admin-token"

# DATABASE_PATH: SQLite database file path
DATABASE_PATH="./data/marketing-ai.db"

# Meta OAuth — prefer configuring via Admin > Integrações (persisted in SQLite)
# These env vars are used as fallback when DB is empty:
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""
APP_URL="http://localhost:3080"
